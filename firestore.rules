rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if ownsUserDoc(userId);

      // Every subcollection beneath a user doc inherits the same
      // ownership check. This covers worlds, their characters and
      // locations, and any future modules (factions, lore) without
      // needing new rule blocks each time.
      match /{document=**} {
        allow read, write: if ownsUserDoc(userId);
      }
    }
  }
}
